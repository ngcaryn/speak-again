{
  "name": "speak-again",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "sync:watch": "powershell -ExecutionPolicy Bypass -File ./scripts/auto-sync.ps1",
    "sync:task:register": "powershell -ExecutionPolicy Bypass -File ./scripts/register-autosync-task.ps1",
    "sync:startup:disable": "powershell -ExecutionPolicy Bypass -File ./scripts/disable-startup-launcher.ps1",
    "sync:task:status": "powershell -ExecutionPolicy Bypass -File ./scripts/check-autosync-task.ps1",
    "build:apk": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.6",
    "expo-av": "^16.0.8",
    "expo-camera": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-sensors": "~55.0.8",
    "expo-speech": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.18",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "eas-cli": "^18.3.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
